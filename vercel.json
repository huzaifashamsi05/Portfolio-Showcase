{
  "framework": "vite",
  "buildCommand": "pnpm install && pnpm -r --if-present run build",
  "outputDirectory": "artifacts/portfolio/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_URL.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
